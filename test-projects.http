### Project CRUD Examples for user_id: 1
# Note: You must run `node scripts/setup-test-user.js` first to get a valid token.
# Replace {{authToken}} with the token generated by the script.

@baseUrl = http://localhost:5000/api
@contentType = application/json
@authToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwiZW1haWwiOiJqZW5uZXRvcmF6bXlyYWRvd2EwNUBnbWFpbC5jb20iLCJpYXQiOjE3NzI1MTYyNTQsImV4cCI6MTc3NTEwODI1NH0.o3TNX_pAGoGzc78dS0qzR2qSagwlO8U9zYBy5jY1d4A

### 1. Create a Project
# @name createProject
POST {{baseUrl}}/projects
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "project_name": "Test Project for User 1",
    "generated_code": "console.log('User 1 Project');",
    "user_prompt": "Create a project for user 1"
}

### Capture Project ID
@projectId = {{createProject.response.body.id}}

### 2. Get All Projects (for user_id: 1)
# @name getProjects
GET {{baseUrl}}/projects
Authorization: Bearer {{authToken}}

### 3. Get Project by ID
# @name getProjectById
GET {{baseUrl}}/projects/{{projectId}}
Authorization: Bearer {{authToken}}

### 4. Update Project (Automatically creates a version)
# @name updateProject
PUT {{baseUrl}}/projects/{{projectId}}
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
    "project_name": "Updated Test Project",
    "generated_code": "console.log('User 1 Project - Updated');",
    "user_prompt": "Update the project for user 1",
    "version_name": "v1.1"
}

### 5. Get Project Versions
# @name getProjectVersions
GET {{baseUrl}}/projects/{{projectId}}/versions
Authorization: Bearer {{authToken}}

### 6. Delete Project
# @name deleteProject
DELETE {{baseUrl}}/projects/{{projectId}}
Authorization: Bearer {{authToken}}
